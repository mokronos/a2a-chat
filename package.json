{
  "name": "a2a-chat",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./packages/ui/dist/index.js",
  "types": "./packages/ui/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/ui/dist/index.d.ts",
      "import": "./packages/ui/dist/index.js"
    },
    "./styles.css": "./packages/ui/dist/styles.css"
  },
  "scripts": {
    "dev:inspector": "bun run --cwd apps/server dev",
    "build:inspector": "bun run --cwd apps/server build:web",
    "dev": "bun run --cwd apps/server dev",
    "build": "bun run build:server",
    "build:server": "bun run --cwd apps/server build",
    "build:api": "bun run --cwd packages/api build",
    "build:react": "bun run --cwd packages/react build",
    "build:packages": "bun run build:api && bun run build:react && bun run --cwd packages/ui build",
    "build:ui": "bun run build:react && bun run --cwd packages/ui build",
    "registry:build": "shadcn build",
    "bunx:server": "bunx --package a2a-chat-server@file:$PWD/apps/server a2a-chat-server",
    "pack:server": "bun pm pack --cwd apps/server",
    "version:patch": "bun pm version patch",
    "version:minor": "bun pm version minor",
    "version:major": "bun pm version major",
    "typecheck": "bun run --cwd packages/api typecheck && bun run --cwd packages/react typecheck && bun run --cwd packages/ui typecheck && bun tsc --noEmit",
    "prepare": "bun run build:ui",
    "dev:server": "bun run --cwd apps/server dev"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.75.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "effect": "^3.21.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "react": "^19.0.0",
    "shadcn": "^4.2.0",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@tailwindcss/cli": "^4.1.14",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
