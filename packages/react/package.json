{
  "name": "@mokronos/a2a-react",
  "version": "0.3.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mokronos/a2a-chat.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/mokronos/a2a-chat#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@tanstack/react-query": "^5.75.5",
    "effect": "^3.21.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
