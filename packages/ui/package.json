{
  "name": "@mokronos/a2a-chat-ui",
  "version": "0.0.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mokronos/a2a-chat.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/mokronos/a2a-chat#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --minify",
    "dev:js": "tsup src/index.ts --format esm --dts --watch",
    "dev:css": "tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --watch",
    "dev": "bun run dev:js & bun run dev:css & wait",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@mokronos/a2a-react": "0.0.2",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.193",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "react": "^19.0.0",
    "shadcn": "^4.2.0",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@types/react": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
