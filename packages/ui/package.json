{
  "name": "@mokronos/a2a-chat-ui",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --minify",
    "dev:js": "tsup src/index.ts --format esm --dts --watch",
    "dev:css": "tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --watch",
    "dev": "bun run dev:js & bun run dev:css & wait",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@tanstack/react-query": "^5.75.5",
    "@base-ui/react": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.0",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@types/react": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
