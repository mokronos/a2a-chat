{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./packages/ui/src/*"],
            "@mokronos/a2a-chat-api": ["./packages/api/src/index.ts"],
            "@mokronos/a2a-react": ["./packages/react/src/index.ts"],
            "@mokronos/a2a-chat-ui": ["./packages/ui/src/index.ts"]
        },
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "jsx": "react-jsx",
        "allowJs": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false,
        "plugins": [
            {
                "name": "@effect/language-service"
            }
        ]
    },
    "exclude": ["node_modules", "dist", "packages/*/dist", "apps/*/dist", "apps/*/public"]
}
